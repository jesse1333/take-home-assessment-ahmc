{
  "name": "take-home-assessment-ahmc",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w api",
    "build": "npm run build -w web",
    "start": "npm run start -w web",
    "lint": "npm run lint -w web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
